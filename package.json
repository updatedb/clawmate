{
  "name": "clawmate-terminal-assets",
  "private": true,
  "scripts": {
    "build:terminal": "esbuild dev/frontend/terminal/index.ts --bundle --format=iife --global-name=ClawMateTerminal --target=es2021 --outfile=dev/static/dist/terminal.js --sourcemap",
    "typecheck": "tsc --noEmit",
    "test:terminal": "vitest run dev/frontend/terminal",
    "test": "npm run typecheck && npm run test:terminal"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-serialize": "0.14.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "esbuild": "0.24.2",
    "jsdom": "25.0.1",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
